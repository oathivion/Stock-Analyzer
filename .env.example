PORT=3000

# Optional: enables durable cache persistence. JSON files remain the local fallback.
DATABASE_URL=

# Optional: enables Alpha Vantage quote data.
# Without this key, the app uses built-in demo market data.
ALPHA_VANTAGE_API_KEY=

# Recommended for SEC EDGAR API requests. Use a real app/contact string.
SEC_USER_AGENT=StockAnalyzer/1.0 your-email@example.com
